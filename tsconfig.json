{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "types": ["node"],


    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Recommended Options
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "esModuleInterop": true, 
    "typeRoots": [
      "./node_modules/@types",
      "./node_modules/@discordjs/typings"
    ],
    "outDir": "./dist",
    "rootDir": "."
  }
}
